{
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "checkJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "lib": ["dom", "es2020"],
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "outDir": "dist",
    "skipLibCheck": true,
    "strictNullChecks": true,
    "target": "es2020"
  },
  "include": ["./src"]
}
