{
  "$schema": "https://v2-5-7.turborepo.dev/schema.json",
  "globalEnv": ["BUILD_VERSION"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "env": ["OLAPPROXY_TARGET", "OLAPPROXY_JWTAUTH"],
      "persistent": true
    }
  }
}
