{
  "name": "@datawheel/tesseract-ui-repo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "mono:publish": "node scripts/publish.js",
    "mono:release": "node scripts/release.js",
    "release:status": "changeset status",
    "release:version": "changeset version",
    "release:publish": "pnpm run build && changeset publish"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt --write"
    ]
  },
  "dependencies": {
    "args": "^5.0.0",
    "chosen": "0.0.2",
    "semver": "^7.3.0",
    "simple-git": "^3.16.1",
    "turbo": "^2.5.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.8.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "esbuild"
    ]
  }
}
